# === SUPABASE ===
# 1) Crie um projeto no Supabase
# 2) Abra SQL Editor e rode /supabase/schema.sql
# 3) Va em Project Settings -> API e copie:
#    - Project URL -> SUPABASE_URL
#    - service_role key -> SUPABASE_SERVICE_ROLE_KEY (NUNCA usar no front)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# === ADMIN AUTH (VERCEL) ===
# Configure estas variaveis na Vercel:
# Vercel -> Project -> Settings -> Environment Variables
# - ADMIN_PASSWORD: senha unica do dashboard
# - JWT_SECRET: string forte e aleatoria (usada para assinar sessao e hash de IP)
ADMIN_PASSWORD=
JWT_SECRET=

# === CORS / ORIGIN ===
# Usado para restringir origem dos requests para seu dominio final
ALLOWED_ORIGIN=https://www.comercias.com.br

# === ANALYTICS CONTROLS ===
# ANALYTICS_ENABLED=false desativa ingestao no backend (/api/track)
ANALYTICS_ENABLED=true

# REACT_APP_DISABLE_ANALYTICS=true desativa inicializacao do tracking no front (nao e segredo)
REACT_APP_DISABLE_ANALYTICS=false

# IMPORTANTE:
# - NUNCA use prefixo REACT_APP_ para segredos
# - SUPABASE_SERVICE_ROLE_KEY deve existir somente no backend (/api)
